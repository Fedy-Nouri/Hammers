generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String
  firstName              String?
  lastName               String?
  avatarUrl              String?
  refreshTokenHash       String?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  subscriptionPlan       String    @default("free")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  conversations     Conversation[]
  googleIntegration GoogleIntegration?
  meetings          Meeting[]

  @@map("users")
}

model GoogleIntegration {
  id                    String   @id @default(uuid())
  userId                String   @unique
  googleEmail           String
  encryptedAccessToken  String
  encryptedRefreshToken String
  tokenExpiresAt        DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  lastSyncedAt DateTime?
  syncToken    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_integrations")
}

model Meeting {
  id            String   @id @default(uuid())
  userId        String
  googleEventId String
  title         String
  description   String?
  location      String?
  startTime     DateTime
  endTime       DateTime
  meetLink      String?
  attendees     Json     @default("[]")
  htmlLink      String?
  status          String   @default("confirmed")
  assistantStatus String   @default("none")
  createdAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  botJob            BotJob?
  transcriptSegments TranscriptSegment[]
  analysis          MeetingAnalysis?
  actionItems       ActionItem[]
  decisions         Decision[]
  risks             Risk[]

  @@unique([userId, googleEventId])
  @@index([userId, startTime])
  @@map("meetings")
}

model BotJob {
  id        String    @id @default(uuid())
  meetingId String    @unique
  status    String    @default("pending")
  attempts  Int       @default(0)
  lastError String?
  startedAt DateTime?
  stoppedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("bot_jobs")
}

model TranscriptSegment {
  id         String   @id @default(uuid())
  meetingId  String
  speaker    Int?
  text       String
  startMs    Int
  endMs      Int
  confidence Float?
  createdAt  DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, startMs])
  @@map("transcript_segments")
}

/// Rolling AI analysis state for a meeting (MC-010). Holds the incrementally
/// maintained summary plus a watermark of how far through the transcript the
/// analyzer has processed, so each cycle only feeds new segments to the model.
model MeetingAnalysis {
  id              String   @id @default(uuid())
  meetingId       String   @unique
  summary         String   @default("")
  processedUpToMs Int      @default(0)
  segmentsSeen    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_analyses")
}

/// Detected task with an optional owner (MC-011). User-editable: `task`,
/// `assignee`, and `status` can be changed via the API. `dedupeKey` is a
/// normalized form of the task used to avoid re-inserting the same item.
model ActionItem {
  id         String   @id @default(uuid())
  meetingId  String
  task       String
  assignee   String?
  confidence Float    @default(0)
  status     String   @default("open")
  dedupeKey  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, dedupeKey])
  @@index([meetingId])
  @@map("action_items")
}

/// Important decision captured during the meeting (MC-012). `dedupeKey`
/// enforces uniqueness so the same decision isn't recorded twice.
model Decision {
  id        String   @id @default(uuid())
  meetingId String
  text      String
  dedupeKey String
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, dedupeKey])
  @@index([meetingId])
  @@map("decisions")
}

/// Risk or blocker raised during the meeting (MC-013). `category` buckets the
/// item (risk | blocker | dependency) and `transcriptRefMs` links back to the
/// supporting transcript line.
model Risk {
  id              String   @id @default(uuid())
  meetingId       String
  text            String
  category        String   @default("risk")
  transcriptRefMs Int?
  dedupeKey       String
  createdAt       DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, dedupeKey])
  @@index([meetingId])
  @@map("risks")
}

model Agent {
  id            String   @id
  name          String
  description   String?
  enabled       Boolean  @default(true)
  configuration Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conversations Conversation[]

  @@map("agents")
}

enum MessageRole {
  user
  assistant
  system
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  agentId   String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    Agent     @relation(fields: [agentId], references: [id])
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model AiUsageLog {
  id               String   @id @default(uuid())
  userId           String?
  agentId          String?
  conversationId   String?
  provider         String
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costUsd          Float    @default(0)
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([agentId])
  @@map("ai_usage_logs")
}
