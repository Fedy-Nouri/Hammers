generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String
  firstName              String?
  lastName               String?
  avatarUrl              String?
  refreshTokenHash       String?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  subscriptionPlan       String    @default("free")
  stripeCustomerId       String?   @unique
  subscriptionStatus     String?
  currentPeriodEnd       DateTime?
  role                   String    @default("user")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  conversations     Conversation[]
  googleIntegration GoogleIntegration?
  meetings          Meeting[]
  jobProfile        JobProfile?
  jobApplications   JobApplication[]
  jobScrapeJobs     JobScrapeJob[]
  installedAgents   InstalledAgent[]

  @@map("users")
}

model GoogleIntegration {
  id                    String   @id @default(uuid())
  userId                String   @unique
  googleEmail           String
  encryptedAccessToken  String
  encryptedRefreshToken String
  tokenExpiresAt        DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  lastSyncedAt DateTime?
  syncToken    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_integrations")
}

model Meeting {
  id            String   @id @default(uuid())
  userId        String
  googleEventId String
  title         String
  description   String?
  location      String?
  startTime     DateTime
  endTime       DateTime
  meetLink      String?
  attendees     Json     @default("[]")
  htmlLink      String?
  status          String   @default("confirmed")
  assistantStatus String   @default("none")
  createdAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  botJob            BotJob?
  transcriptSegments TranscriptSegment[]
  analysis          MeetingAnalysis?
  actionItems       ActionItem[]
  decisions         Decision[]
  risks             Risk[]
  report            MeetingReport?
  followUpEmail     FollowUpEmail?

  @@unique([userId, googleEventId])
  @@index([userId, startTime])
  @@map("meetings")
}

model BotJob {
  id            String    @id @default(uuid())
  meetingId     String    @unique
  botInstanceId String?
  status        String    @default("pending")
  attempts      Int       @default(0)
  lastError     String?
  startedAt     DateTime?
  stoppedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("bot_jobs")
}

/// A registered meeting-bot container (MC fleet / SC-001). Each container owns
/// one Google account and joins one meeting at a time. `currentMeetingId` is the
/// meeting it is presently assigned to (null when idle); its uniqueness ensures a
/// meeting is claimed by at most one instance. The backend stores only the
/// container's reachable `baseUrl` and busy/health state — never Google credentials.
model BotInstance {
  id               String    @id @default(uuid())
  label            String
  baseUrl          String
  status           String    @default("offline")
  currentMeetingId String?   @unique
  lastHeartbeatAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("bot_instances")
}

model TranscriptSegment {
  id         String   @id @default(uuid())
  meetingId  String
  speaker    Int?
  text       String
  startMs    Int
  endMs      Int
  confidence Float?
  createdAt  DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, startMs])
  @@map("transcript_segments")
}

/// Rolling AI analysis state for a meeting (MC-010). Holds the incrementally
/// maintained summary plus a watermark of how far through the transcript the
/// analyzer has processed, so each cycle only feeds new segments to the model.
model MeetingAnalysis {
  id              String   @id @default(uuid())
  meetingId       String   @unique
  summary         String   @default("")
  processedUpToMs Int      @default(0)
  segmentsSeen    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_analyses")
}

/// Detected task with an optional owner (MC-011). User-editable: `task`,
/// `assignee`, and `status` can be changed via the API. `dedupeKey` is a
/// normalized form of the task used to avoid re-inserting the same item.
model ActionItem {
  id         String   @id @default(uuid())
  meetingId  String
  task       String
  assignee   String?
  confidence Float    @default(0)
  status     String   @default("open")
  dedupeKey  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, dedupeKey])
  @@index([meetingId])
  @@map("action_items")
}

/// Important decision captured during the meeting (MC-012). `dedupeKey`
/// enforces uniqueness so the same decision isn't recorded twice.
model Decision {
  id        String   @id @default(uuid())
  meetingId String
  text      String
  dedupeKey String
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, dedupeKey])
  @@index([meetingId])
  @@map("decisions")
}

/// Risk or blocker raised during the meeting (MC-013). `category` buckets the
/// item (risk | blocker | dependency) and `transcriptRefMs` links back to the
/// supporting transcript line.
model Risk {
  id              String   @id @default(uuid())
  meetingId       String
  text            String
  category        String   @default("risk")
  transcriptRefMs Int?
  dedupeKey       String
  createdAt       DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, dedupeKey])
  @@index([meetingId])
  @@map("risks")
}

/// Post-meeting report generated by the AI (MC-014). Stores the polished
/// executive summary and follow-up recommendations produced after the meeting
/// ends. `status` tracks generation progress: pending → generating → ready | failed.
model MeetingReport {
  id        String   @id @default(uuid())
  meetingId String   @unique
  executive String   @default("")
  followUps Json     @default("[]")
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_reports")
}

/// AI-generated follow-up recap email (MC-015). User can edit subject and body
/// before sending. `status` mirrors MeetingReport.status lifecycle.
model FollowUpEmail {
  id        String   @id @default(uuid())
  meetingId String   @unique
  subject   String   @default("")
  body      String   @default("")
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("followup_emails")
}

model Agent {
  id            String   @id
  name          String
  description   String?
  enabled       Boolean  @default(true)
  minPlan       String   @default("free")
  configuration Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conversations Conversation[]
  installs      InstalledAgent[]

  @@map("agents")
}

/// Per-user agent install (MK-001). Access to an agent = an install row AND the user's plan
/// rank >= the agent's minPlan rank. Uninstalling removes access but never deletes history.
model InstalledAgent {
  id        String   @id @default(uuid())
  userId    String
  agentId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@map("installed_agents")
}

enum MessageRole {
  user
  assistant
  system
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  agentId   String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    Agent     @relation(fields: [agentId], references: [id])
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

/// Per-user configuration for the Job Application Agent (JA-001): the uploaded
/// resume (Blob URL + extracted text used for AI scoring) and the job-search
/// preferences that drive matching. One row per user.
model JobProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  resumeUrl     String?
  resumeText    String?
  desiredTitles String[]
  locations     String[]
  remotePref    String   @default("any")
  salaryMin     Int?
  keywords      String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_profiles")
}

/// A job the user is tracking (JA-002). Ingested manually for now (a scraper bot
/// lands in JA-007). The AI scores it against the user's resume on ingest and a
/// cover letter is generated on demand (JA-003). `status` drives the kanban.
model JobApplication {
  id           String    @id @default(uuid())
  userId       String
  source       String    @default("manual")
  url          String?
  title        String
  company      String
  location     String?
  description  String
  matchScore   Float?
  matchSummary String?
  strengths    String[]
  gaps         String[]
  coverLetter  String?
  status       String    @default("new")
  notes        String?
  appliedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("job_applications")
}

/// A scrape run for one user (JA-007). The dedicated job-bot fleet claims a queued
/// job, scrapes LinkedIn for the user's preferences, and posts results to the
/// bot-only ingest endpoint. `found` counts new applications created this run.
model JobScrapeJob {
  id                String    @id @default(uuid())
  userId            String
  status            String    @default("queued")
  requested         String    @default("scheduled")
  jobBotInstanceId  String?
  found             Int       @default(0)
  attempts          Int       @default(0)
  lastError         String?
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
  @@map("job_scrape_jobs")
}

/// A registered job-bot scraper container (JA-007). Kept separate from the meeting
/// fleet's BotInstance: scraping is short batch work, so this fleet has its own
/// registry. `currentScrapeJobId` is the scrape it is presently running (null when
/// idle); its uniqueness ensures a scrape is claimed by at most one instance.
model JobBotInstance {
  id                 String    @id @default(uuid())
  label              String
  baseUrl            String
  status             String    @default("offline")
  currentScrapeJobId String?   @unique
  lastHeartbeatAt    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("job_bot_instances")
}

model AiUsageLog {
  id               String   @id @default(uuid())
  userId           String?
  agentId          String?
  conversationId   String?
  provider         String
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costUsd          Float    @default(0)
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([agentId])
  @@map("ai_usage_logs")
}

/// Audit + dedupe log for outbound email (NT-001). `status` = sent | failed | logged
/// (logged = console driver when no provider is configured). `period` (e.g. "2026-06")
/// scopes once-per-month notifications like the quota warning.
model EmailLog {
  id        String   @id @default(uuid())
  userId    String?
  to        String
  type      String
  period    String?
  status    String   @default("logged")
  error     String?
  createdAt DateTime @default(now())

  @@index([userId, type, period])
  @@map("email_logs")
}
