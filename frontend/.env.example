# Absolute origin of the backend API for split-origin deploys (frontend on its own domain),
# e.g. VITE_API_URL="https://api.example.com". The backend must allow this page's origin via
# CORS_ORIGINS. Leave empty for the default same-origin setup where nginx reverse-proxies
# /api to the backend (docker compose). Vite inlines VITE_* vars at build time.
VITE_API_URL=""
