PORT=3001
# Stable identity for this container in the fleet + its reachable URL (used for
# self-registration with the backend registry). One Google account per container.
BOT_ID="bot-1"
SELF_URL="http://localhost:3001"
BOT_GOOGLE_EMAIL="bot@yourcompany.com"
BOT_GOOGLE_PASSWORD="your-bot-password"
BACKEND_URL="http://localhost:3000"
BOT_CALLBACK_SECRET="your-shared-secret"
DEEPGRAM_API_KEY="your-deepgram-key"
BOT_HEADLESS=true
