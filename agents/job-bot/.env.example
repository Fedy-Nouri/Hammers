# HTTP port the bot listens on
PORT=3002

# Stable identity for this container in the scrape fleet + its reachable URL
# (used for self-registration with the backend scrape registry).
BOT_ID=job-bot-1
SELF_URL=http://localhost:3002

# Backend base URL + the shared secret for the x-bot-secret header.
BACKEND_URL=http://localhost:3000
BOT_CALLBACK_SECRET=

# Platform LinkedIn account this container scrapes as (NOT a real user's account).
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Optional proxy to reduce blocks/bans, e.g. http://user:pass@host:port
PROXY_URL=

# Browser + scrape behaviour
BOT_HEADLESS=true
BOT_USER_DATA_DIR=.bot-profile
MAX_JOBS_PER_SCRAPE=10
